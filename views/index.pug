doctype html
html(lang='en')
  head
    meta(charset='utf-8')
    meta(http-equiv='X-UA-Compatible', content='IE=edge')
    meta(name='viewport', content='width=device-width, shrink-to-fit=no, initial-scale=1.0, maximum-scale=1.0, user-scalable=0')
    title BINK.js #{version}
    //jQuery
    script(src='https://cdn.jsdelivr.net/npm/jquery@4.0.0/dist/jquery.min.js', integrity='sha256-OaVG6prZf4v69dPg6PhVattBXkcOWQB62pdZ3ORyrao=', crossorigin='anonymous' referrerpolicy='no-referrer')

    //Popper is required by Tempus Dominus
    script(src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/2.11.8/umd/popper.min.js" integrity="sha512-TPh2Oxlg1zp+kz3nFA0C5vVC6leG/6mm1z9+mA81MI5eaUVqasPLO8Cuk4gMF4gUfP5etR73rgU/8PNMsSesoQ==" crossorigin="anonymous" referrerpolicy="no-referrer")

    //The bootstrap javascript library
    script(src='https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.8/js/bootstrap.min.js' integrity='sha512-nKXmKvJyiGQy343jatQlzDprflyB5c+tKCzGP3Uq67v+lmzfnZUi/ZT+fc6ITZfSC5HhaBKUIvr/nTLCV+7F+Q==' crossorigin='anonymous' referrerpolicy='no-referrer')

    //Bootstrap DARKLY Theme -- should not need further customization!
    link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/bootswatch/5.3.8/darkly/bootstrap.min.css", integrity="sha512-+uC0Ar9AG4/j/iF0Ug22TO9D17MAbD94K7J8h17EzXzN3D5kcOpYQdF4OuiLraHSibCVhz4DIcqwsDboRMVStg==", crossorigin="anonymous" referrerpolicy='no-referrer')
    //FontAwesome Icons/Sprites usable with Bootstrap
    link(rel="stylesheet", href='https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@7.3.0/css/all.min.css' integrity='sha512-ApSLB1Pd3/bZN8fWB/RG9YhN/7bd9Hkf3AGaE2mPfebjrxagjuBtx2GcgdqIlJkUzwylBo61r9Xa9NmgBI0swA==' crossorigin='anonymous' referrerpolicy='no-referrer')
    //Howler.js import
    script(src='https://cdnjs.cloudflare.com/ajax/libs/howler/2.2.4/howler.min.js' integrity='sha512-xi/RZRIF/S0hJ+yJJYuZ5yk6/8pCiRlEXZzoguSMl+vk2i3m6UjUO/WcZ11blRL/O+rnj94JRGwt/CHbc9+6EA==' crossorigin='anonymous' referrerpolicy='no-referrer')
    // The BINK Client-side JavaScript Application
    script(src='js/bink.js')
  body
    #scriptHolders
    nav.navbar.navbar-expand-sm.navbar-dark.bg-primary
      .container-fluid
        a.navbar-brand(href='#') BINK v#{version}
        button.navbar-toggler(type='button' data-bs-toggle='collapse' data-bs-target='#navbarSupportedContent' aria-controls='navbarSupportedContent' aria-expanded='false' aria-label='Toggle navigation')
          span.navbar-toggler-icon
        #navbarSupportedContent.collapse.navbar-collapse
          ul.navbar-nav.me-auto
            li.nav-item
              a#recentButton.nav-link.active(aria-current='page' href='javascript:') Recent
            li.nav-item
              a#browseButton.nav-link(href='javascript:') Browse
            li.nav-item
              a#historyButton.nav-link(href='javascript:') History
            li.nav-item
              a#mapButton.nav-link(href='javascript:') Map
            li#adminItem.nav-item
              a#adminButton.nav-link(href='javascript:') Admin
    #main(style="margin-bottom: 150px")
    container-fluid.bg-primary.fixed-bottom.pt-2.ps-1
      .row.align-items-center
        .col-xl-3.col-lg-3.col-md-4.col-sm-5.col-12
          #playButton.btn.btn-primary(type=button)
            i.fa-solid.fa-play
          #pauseButton.btn.btn-primary.disabled(type=button)
            i.fa-solid.fa-pause
          #stopButton.btn.btn-primary(type=button)
            i.fa-solid.fa-stop
          #prevButton.btn.btn-primary(type=button)
            i.fa-solid.fa-step-backward
          #nextButton.btn.btn-primary(type=button)
            i.fa-solid.fa-step-forward
          #playlistButton.btn.btn-primary(type=button)
            i.fa-solid.fa-list
        .col-xl-4.col-lg-4.col-md-3.col-sm-2.col-6
          input.w-100#position(type="range", min=0, max=0, disabled)
        .col-xl-2.col-lg-2.col-md-2.col-sm-2.col-6
          p#timeAndCursor.ms-2.mt-2 -:-- / -:--
        .col-xl-3.col-lg-3.col-md-3.col-sm-3.col-6
          p#currentlyPlaying.ms-2.mt-2
            em Nothing playing...
    #binkAlertModal.modal(tabindex='-1')
      .modal-dialog
        .modal-content
          .modal-header
            h5#binkAlertTitle.modal-title ...
            button.btn-close(type='button' data-bs-dismiss='modal' aria-label='Close')
          .modal-body
            p#binkAlertText ...
          .modal-footer
            button.btn.btn-secondary(type='button' data-bs-dismiss='modal') Close
